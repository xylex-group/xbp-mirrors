{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xylex-group/xbp/main/schemas/xbp.project.schema.json",
  "title": "XBP project config (.xbp/xbp.yaml)",
  "description": "Canonical project configuration for the XBP CLI. Used by editors via yaml-language-server / VS Code YAML extension.",
  "type": "object",
  "additionalProperties": true,
  "required": ["project_name", "port", "build_dir"],
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Human-readable project name (used in dashboards, release titles, and service defaults)."
    },
    "version": {
      "type": "string",
      "description": "Project version string (semver recommended). Default 0.1.0 when omitted on parse.",
      "default": "0.1.0",
      "examples": ["0.1.0", "1.14.2", "4.0.0"]
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "Primary service port for the root project / default service."
    },
    "build_dir": {
      "type": "string",
      "description": "Build / working directory relative to the project root (often `.`)."
    },
    "app_type": {
      "type": ["string", "null"],
      "description": "Detected or declared application type (rust, nextjs, nodejs, docker, python, …)."
    },
    "target": {
      "type": ["string", "null"],
      "description": "Legacy alias for app/runtime target (prefer app_type / per-service target)."
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Legacy default git branch for the root service."
    },
    "build_command": {
      "type": ["string", "null"],
      "description": "Root build command when not using multi-service `services[].commands`."
    },
    "start_command": {
      "type": ["string", "null"],
      "description": "Root start command."
    },
    "install_command": {
      "type": ["string", "null"],
      "description": "Root install/bootstrap command."
    },
    "environment": {
      "type": ["object", "null"],
      "description": "Environment variables (values may be literals or `${ENV}` placeholders).",
      "additionalProperties": { "type": "string" }
    },
    "url": {
      "type": ["string", "null"],
      "description": "Public URL for the primary service."
    },
    "url_storybook": {
      "type": ["string", "null"]
    },
    "port_storybook": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 65535
    },
    "crate_name": {
      "type": ["string", "null"],
      "description": "Legacy Rust crate name for single-crate projects."
    },
    "npm_script": {
      "type": ["string", "null"],
      "description": "Legacy npm script name for start."
    },
    "services": {
      "type": ["array", "null"],
      "description": "Multi-service definitions (discovered by `xbp version discover` or hand-authored).",
      "items": { "$ref": "#/$defs/service" }
    },
    "workers": {
      "type": ["array", "null"],
      "description": "Cloudflare Workers (and optional Containers) managed via `xbp cloudflare` / workers commands.",
      "items": { "$ref": "#/$defs/worker" }
    },
    "version_targets": {
      "type": "array",
      "description": "Project-level version manifest paths (Cargo.toml, package.json, …) always bumped with the project version.",
      "items": { "type": "string" }
    },
    "version_domains": {
      "type": "array",
      "description": "Explicit multi-version domain policies (`xbp version domain`).",
      "items": { "$ref": "#/$defs/versionDomain" }
    },
    "ignore_paths": {
      "type": "array",
      "description": "Gitignore-style paths skipped by service discovery and version-target discovery (not worktree-watch). Aliases: ignored_paths, xbpignore.",
      "items": { "type": "string" }
    },
    "watch_ignore_paths": {
      "type": "array",
      "description": "Worktree-watch-only ignore patterns. Alias: watch_ignore.",
      "items": { "type": "string" }
    },
    "versioning_disabled": {
      "type": "array",
      "description": "Service names or root globs excluded from version bumps.",
      "items": { "type": "string" }
    },
    "release_disabled": {
      "type": "array",
      "description": "Service names or root globs excluded from releases.",
      "items": { "type": "string" }
    },
    "linear": {
      "oneOf": [
        { "$ref": "#/$defs/linear" },
        { "type": "null" }
      ],
      "description": "Repo-scoped Linear settings (team defaults, release initiatives)."
    },
    "github": {
      "oneOf": [
        { "type": "string", "description": "Bare owner/repo shorthand (maps to github.repository)." },
        { "$ref": "#/$defs/github" },
        { "type": "null" }
      ],
      "description": "GitHub repository, auto-push, release-branch, and runners settings. Accepts a bare owner/repo string, an object, or null."
    },
    "publish": {
      "oneOf": [
        { "$ref": "#/$defs/publish" },
        { "type": "null" }
      ],
      "description": "npm / crates.io / cargo-dist publish settings."
    },
    "openapi": {
      "oneOf": [
        { "$ref": "#/$defs/projectOpenapi" },
        { "type": "null" }
      ],
      "description": "Project-level OpenAPI generation settings."
    },
    "todos": {
      "oneOf": [
        { "$ref": "#/$defs/todos" },
        { "type": "null" }
      ],
      "description": "TODO→issue automation defaults for `xbp todos` (project overrides global)."
    },
    "database": {
      "oneOf": [
        { "$ref": "#/$defs/database" },
        { "type": "null" }
      ]
    },
    "systemd": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/systemd" },
        { "type": "null" }
      ]
    },
    "systemd_service_name": {
      "type": ["string", "null"]
    },
    "kafka_brokers": { "type": ["string", "null"] },
    "kafka_topic": { "type": ["string", "null"] },
    "kafka_public_url": { "type": ["string", "null"] },
    "log_files": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "monitor_url": { "type": ["string", "null"] },
    "monitor_method": {
      "type": ["string", "null"],
      "enum": ["GET", "POST", "HEAD", "PUT", "PATCH", "DELETE", null]
    },
    "monitor_expected_code": {
      "type": ["integer", "null"],
      "minimum": 100,
      "maximum": 599
    },
    "monitor_interval": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Monitor interval in seconds."
    },
    "oci": {
      "$ref": "#/$defs/ociProject",
      "description": "Project-level OCI registry credentials and defaults. Per-service image config lives under services[].oci."
    },
    "kubernetes": {
      "$ref": "#/$defs/kubernetesProject",
      "description": "Project-level Kubernetes defaults (context, namespace, apply safety). Per-service workload config lives under services[].deploy."
    },
    "deploy": {
      "$ref": "#/$defs/deployProject",
      "description": "Project-level deploy defaults and named service groups for `xbp deploy <target>`. Primary deployable units remain services[]."
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "target", "branch", "port"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Stable service id (not a packaging path; never include crate versions)."
        },
        "target": {
          "type": "string",
          "description": "Runtime/target kind: rust, nextjs, nodejs, expressjs, docker, python, …"
        },
        "branch": {
          "type": "string",
          "description": "Default git branch for this service."
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "root_directory": {
          "type": ["string", "null"],
          "description": "Project-relative service root (e.g. services/athena-auth, crates/cli)."
        },
        "environment": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "string" }
        },
        "url": { "type": ["string", "null"] },
        "healthcheck_path": { "type": ["string", "null"] },
        "restart_policy": {
          "type": ["string", "null"],
          "examples": ["on_failure", "always", "no"]
        },
        "restart_policy_max_failure_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "start_wrapper": {
          "type": ["string", "null"],
          "examples": ["pm2", "systemd", "none"]
        },
        "commands": { "$ref": "#/$defs/serviceCommands" },
        "force_run_from_root": { "type": ["boolean", "null"] },
        "version_targets": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Manifests to bump for this service (Cargo.toml, package.json, …)."
        },
        "watch_paths": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Dirty-tree path prefixes that mark this service as a version candidate."
        },
        "versioning": {
          "type": ["boolean", "null"],
          "description": "When false, exclude from version bumps. Aliases: versioning_enabled, enable_versioning."
        },
        "release": {
          "type": ["boolean", "null"],
          "description": "When false, exclude from releases (bumps may still run). Aliases: release_enabled, enable_release."
        },
        "systemd_service_name": { "type": ["string", "null"] },
        "systemd": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/systemd" },
            { "type": "null" }
          ]
        },
        "openapi": {
          "oneOf": [
            { "$ref": "#/$defs/serviceOpenapi" },
            { "type": "null" }
          ]
        },
        "oci": {
          "oneOf": [
            { "$ref": "#/$defs/serviceOci" },
            { "type": "null" }
          ],
          "description": "Optional OCI image config for this service (used by `xbp deploy` / `xbp oci`)."
        },
        "deploy": {
          "oneOf": [
            { "$ref": "#/$defs/serviceDeploy" },
            { "type": "null" }
          ],
          "description": "Optional release/deploy orchestration for this service (`xbp deploy <name>`). Distinct from commands.deploy (a local script name)."
        }
      }
    },
    "serviceCommands": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "properties": {
        "pre": { "type": ["string", "null"] },
        "install": { "type": ["string", "null"] },
        "build": { "type": ["string", "null"] },
        "start": { "type": ["string", "null"] },
        "dev": { "type": ["string", "null"] }
      },
      "description": "Known keys plus arbitrary custom command names (test, lint, publish, …)."
    },
    "worker": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string" },
        "root": {
          "type": "string",
          "description": "Project-relative Worker root (wrangler.toml / wrangler.jsonc)."
        },
        "script_name": { "type": ["string", "null"] },
        "service": { "type": ["string", "null"] },
        "deploy": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "command": { "type": ["string", "null"] },
            "ci_script": { "type": ["string", "null"] },
            "select_script": { "type": ["string", "null"] }
          }
        },
        "container": {
          "$ref": "#/$defs/workerContainer"
        },
        "containers": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/workerContainer" },
          "description": "Typed Wrangler Containers definitions. The singular `container` field remains supported for legacy projects."
        },
        "durable_objects": {
          "$ref": "#/$defs/workerDurableObjects"
        }
      }
    },
    "workerContainer": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "class_name": { "type": ["string", "null"] },
        "binding": { "type": ["string", "null"] },
        "dockerfile": { "type": ["string", "null"] },
        "build_context": { "type": ["string", "null"] },
        "image": { "type": ["string", "null"] },
        "port": { "type": ["integer", "null"] },
        "instance_type": { "type": ["string", "null"] },
        "max_instances": { "type": ["integer", "null"], "minimum": 0 },
        "application_id": { "type": ["string", "null"] },
        "healthcheck_path": { "type": ["string", "null"] },
        "health_urls": { "type": "array", "items": { "type": "string" } },
        "expected_image_name": { "type": ["string", "null"] },
        "rollout_active_grace_period": { "type": ["integer", "null"], "minimum": 0 },
        "rollout_step_percentage": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 100 } },
        "regions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "workerDurableObjectBinding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "class_name"],
      "properties": {
        "name": { "type": "string" },
        "class_name": { "type": "string" },
        "script_name": { "type": ["string", "null"] },
        "environment": { "type": ["string", "null"] }
      }
    },
    "workerDurableObjectMigration": {
      "type": "object",
      "additionalProperties": true,
      "required": ["tag"],
      "properties": {
        "tag": { "type": "string" },
        "new_classes": { "type": "array", "items": { "type": "string" } },
        "new_sqlite_classes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "workerDurableObjectNamespace": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "class"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "script": { "type": ["string", "null"] },
        "class": { "type": "string" },
        "class_name": { "type": ["string", "null"] },
        "use_sqlite": { "type": "boolean" },
        "use_containers": { "type": "boolean" }
      }
    },
    "workerDurableObjects": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "bindings": { "type": "array", "items": { "$ref": "#/$defs/workerDurableObjectBinding" } },
        "migrations": { "type": "array", "items": { "$ref": "#/$defs/workerDurableObjectMigration" } },
        "namespaces": { "type": "array", "items": { "$ref": "#/$defs/workerDurableObjectNamespace" } }
      }
    },
    "versionDomain": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "root", "version"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "version": { "type": "string" },
        "owned_package_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "owned_package_prefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "version_surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "path"],
            "properties": {
              "kind": { "type": "string" },
              "path": { "type": "string" },
              "key": { "type": ["string", "null"] },
              "marker": { "type": ["string", "null"] },
              "packages": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "allowed_bumps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "image_version_probe": { "type": ["string", "null"] },
        "live_health_urls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cloudflare_app": { "type": ["string", "null"] }
      }
    },
    "linear": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "default_team_id": { "type": ["string", "null"] },
        "default_team_key": {
          "type": ["string", "null"],
          "description": "Team key such as XLX."
        },
        "organization_name": {
          "type": ["string", "null"],
          "description": "Linear org slug for human URLs. Alias: org_name."
        },
        "release": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "description": "Release → Linear initiative publish settings."
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": ["string", "null"],
          "description": "owner/repo when origin cannot be inferred. Also accepted as a bare string under github:."
        },
        "auto_push_on_commit": {
          "type": "boolean",
          "default": true,
          "description": "When true, auto-commit flows (`xbp commit`, version bumps, generated config commits) push after creating the commit. Push uses stash-safe rebase when behind/diverged (see also `xbp push`)."
        },
        "release_branch": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "runners": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "npm": {
          "oneOf": [
            { "$ref": "#/$defs/publishTarget" },
            { "type": "null" }
          ]
        },
        "crates": {
          "oneOf": [
            { "$ref": "#/$defs/publishTarget" },
            { "type": "null" }
          ]
        },
        "dist": {
          "oneOf": [
            { "$ref": "#/$defs/publishDist" },
            { "type": "null" }
          ]
        }
      }
    },
    "publishTarget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": ["boolean", "null"] },
        "package_name": { "type": ["string", "null"] },
        "working_directory": { "type": ["string", "null"] },
        "manifest_path": { "type": ["string", "null"] },
        "token": { "type": ["string", "null"] },
        "preflight_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "publish_command": { "type": ["string", "null"] },
        "use_wsl": { "type": ["boolean", "null"] },
        "wsl_distribution": { "type": ["string", "null"] },
        "generate_npmrc": { "type": ["boolean", "null"] },
        "access": { "type": ["string", "null"] }
      }
    },
    "publishDist": {
      "type": "object",
      "additionalProperties": true,
      "description": "cargo-dist settings for GitHub release assets/installers.",
      "properties": {
        "enabled": { "type": ["boolean", "null"] },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "installers": {
          "type": "array",
          "items": {
            "type": "string",
            "examples": ["shell", "msi", "powershell", "npm", "homebrew"]
          }
        },
        "targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts_modes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alias: artifacts. host | local | global."
        },
        "allow_dirty": { "type": ["boolean", "null"] },
        "generate_ci": { "type": ["boolean", "null"] },
        "tool": { "type": ["string", "null"] }
      }
    },
    "projectOpenapi": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": ["boolean", "null"] },
        "auto_detect_services": { "type": ["boolean", "null"] },
        "generate_on_release": { "type": ["boolean", "null"] },
        "service_defaults": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "aggregate": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      }
    },
    "serviceOpenapi": {
      "type": "object",
      "additionalProperties": true,
      "description": "Per-service OpenAPI overrides."
    },
    "systemd": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "environment_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "config_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "read_write_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "runtime_directories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "state_directories": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": ["boolean", "null"] },
        "backend": { "type": ["string", "null"] },
        "url_env": { "type": ["string", "null"] },
        "key_env": { "type": ["string", "null"] },
        "schema": { "type": ["string", "null"] }
      }
    },
    "todos": {
      "type": "object",
      "additionalProperties": true,
      "description": "Defaults for `xbp todos scan|sync` (project overrides global config).",
      "properties": {
        "default_to": {
          "type": ["string", "null"],
          "enum": ["linear", "github", "both", null]
        },
        "auto_yes": { "type": ["boolean", "null"] },
        "prompt_sync_after_scan": { "type": ["boolean", "null"] },
        "linear_labels": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "github_labels": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "linear_assignee": { "type": ["string", "null"] },
        "linear_project": {
          "type": ["string", "null"],
          "description": "Linear project name, id, or slug for created issues."
        },
        "watch_paths": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Repo-relative path prefixes to scan for TODOs (empty = whole tree)."
        },
        "linear_link_wait_secs": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Seconds to wait for Linear GitHub auto-link after creating GitHub issues."
        },
        "linear_link_poll_ms": {
          "type": ["integer", "null"],
          "minimum": 100,
          "description": "Poll interval in ms while waiting for Linear auto-link."
        },
        "purge_duplicate_linear": {
          "type": ["boolean", "null"],
          "description": "Archive xbp-created Linear issues that duplicate auto-linked ones."
        },
        "kinds": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "priority_by_kind": {
          "type": ["object", "null"],
          "additionalProperties": { "type": "integer" }
        },
        "annotate_source": { "type": ["boolean", "null"] }
      }
    },
    "ociProject": {
      "type": "object",
      "additionalProperties": true,
      "description": "Top-level OCI defaults (registries / credentials). Services reference images under services[].oci.",
      "properties": {
        "registries": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/ociRegistry" },
          "description": "Map of registry host → credentials (e.g. ghcr.io)."
        },
        "default_registry": {
          "type": ["string", "null"],
          "description": "Default registry host when services omit a full image host."
        }
      }
    },
    "ociRegistry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider": {
          "type": ["string", "null"],
          "description": "Credential provider hint: github, dockerhub, aws, gcp, azure, generic.",
          "examples": ["github", "dockerhub", "generic"]
        },
        "username": { "type": ["string", "null"] },
        "token_source": {
          "type": ["string", "null"],
          "description": "Where to read the token: github, env:VAR, keychain, etc.",
          "examples": ["github", "env:GHCR_TOKEN"]
        },
        "url": {
          "type": ["string", "null"],
          "description": "Optional registry base URL override."
        }
      }
    },
    "serviceOci": {
      "type": "object",
      "additionalProperties": true,
      "description": "Per-service container image settings.",
      "properties": {
        "image": {
          "type": ["string", "null"],
          "description": "Image repository reference without required tag (e.g. ghcr.io/org/app)."
        },
        "tag": {
          "type": ["string", "null"],
          "description": "Explicit image tag. Prefer tag_from when versioning with XBP."
        },
        "tag_from": {
          "type": ["string", "null"],
          "description": "Derive tag from project_version, service_version, git_sha, or none.",
          "examples": ["project_version", "service_version", "git_sha"]
        },
        "dockerfile": {
          "type": ["string", "null"],
          "description": "Dockerfile path relative to service root_directory or project root."
        },
        "context": {
          "type": ["string", "null"],
          "description": "Build context path (defaults to root_directory or .)."
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Target platforms (e.g. linux/amd64, linux/arm64)."
        },
        "build_args": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "kubernetesProject": {
      "type": "object",
      "additionalProperties": true,
      "description": "Shared Kubernetes defaults for deploy providers.",
      "properties": {
        "default_context": {
          "type": ["string", "null"],
          "description": "kubectl context. Empty string means current context with confirmation policy."
        },
        "default_namespace": {
          "type": ["string", "null"],
          "default": "default"
        },
        "require_context_confirmation_for_apply": {
          "type": "boolean",
          "default": true,
          "description": "When true, mutating apply/deploy prompts unless non-interactive --yes."
        },
        "kubeconfig": {
          "type": ["string", "null"],
          "description": "Optional KUBECONFIG path override."
        }
      }
    },
    "deployProject": {
      "type": "object",
      "additionalProperties": true,
      "description": "Project deploy defaults and groups. Does not replace services[] as the primary deploy unit.",
      "properties": {
        "default_env": {
          "type": ["string", "null"],
          "description": "Default environment name for `xbp deploy` when --env is omitted.",
          "examples": ["production", "staging"]
        },
        "history_dir": {
          "type": ["string", "null"],
          "default": ".xbp/deployments",
          "description": "Directory for deploy plan/run history records."
        },
        "lock_file": {
          "type": ["string", "null"],
          "default": ".xbp/deploy-lock.json",
          "description": "Optional lock file path to prevent concurrent deploys."
        },
        "groups": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/deployGroup" },
          "description": "Named ordered service sets for `xbp deploy <group>` (e.g. athena)."
        }
      }
    },
    "deployGroup": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "services": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Service names in this group (membership)."
        },
        "order": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Deploy order (operator first, then runtimes). Defaults to services order."
        },
        "description": {
          "type": ["string", "null"]
        }
      }
    },
    "serviceDeploy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Per-service deploy orchestration (provider + per-env settings).",
      "properties": {
        "provider": {
          "type": ["string", "null"],
          "description": "Deploy provider: kubernetes, kubernetes-operator, worker, pm2, systemd, …",
          "examples": ["kubernetes", "kubernetes-operator", "worker", "pm2"]
        },
        "envs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/serviceDeployEnv" },
          "description": "Environment-keyed deploy settings (production, staging, …)."
        }
      }
    },
    "serviceDeployEnv": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "namespace": { "type": ["string", "null"] },
        "replicas": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "health": {
          "type": "array",
          "items": { "type": "string" },
          "description": "HTTP(S) health URLs to probe after rollout."
        },
        "kubernetes": {
          "anyOf": [
            { "$ref": "#/$defs/serviceDeployKubernetes" },
            { "type": "null" }
          ],
          "description": "Kubernetes deploy settings for this env; omit or null when provider is not kubernetes."
        }
      }
    },
    "serviceDeployKubernetes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "manifests": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "base": { "type": ["string", "null"] },
            "overlay": { "type": ["string", "null"] }
          }
        },
        "workload": {
          "type": ["string", "null"],
          "description": "kubectl resource for rollout status (e.g. deployment/api)."
        },
        "service": {
          "type": ["string", "null"],
          "description": "Kubernetes Service name."
        },
        "crds_path": {
          "type": ["string", "null"],
          "description": "Path to CRDs for kubernetes-operator provider."
        },
        "install_path": {
          "type": ["string", "null"],
          "description": "Path to operator install manifests."
        },
        "selector": {
          "type": ["string", "null"],
          "description": "Label selector to wait on (operators)."
        }
      }
    }
  }
}
